[Unit]
Description=semantic-blog-search API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/semantic-blog-search
ExecStart=/opt/semantic-blog-search/.venv/bin/python scripts/server.py --config config.yaml
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
